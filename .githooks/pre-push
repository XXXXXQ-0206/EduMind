#!/bin/sh
set -eu

if command -v git-lfs >/dev/null 2>&1; then
  git lfs pre-push "$@"
else
  echo "[pre-push] git-lfs is not installed. Install Git LFS before pushing binary assets."
  exit 2
fi

while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/main|refs/heads/master)
      protected_branch="${remote_ref#refs/heads/}"
      if [ "$remote_sha" != "0000000000000000000000000000000000000000" ]; then
        echo "[pre-push] Direct pushes to $protected_branch are blocked locally."
        echo "Push feature branches and merge by Pull Request."
        echo "Repository maintainers may use --no-verify only for exceptional maintenance."
        exit 1
      fi
      ;;
  esac
done

echo "[pre-push] OK"
