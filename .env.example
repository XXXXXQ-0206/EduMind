########################################
# Server
########################################
HOST=0.0.0.0
PORT=5000
VITE_BACKEND_URL=http://localhost:5000

########################################
# Frontend (for CORS / dev server)
########################################
VITE_FRONTEND_URL=http://localhost:5173
VITE_FRONTEND_PORT=5173
VITE_TIMEOUT=90000

########################################
# Database for Embedding
########################################
db_mode=json

########################################
# Microservice Runtime (Docker Compose defaults)
########################################
# 下面这些值是 Docker Compose 微服务拓扑的默认配置；如果运行本地单进程兼容模式（BACKEND_ROLE=monolith），通常需要改回 json/local/memory/inline 等本地 provider。
POSTGRES_DSN=postgresql://edumind:edumind@postgres:5432/edumind
OBJECT_STORE_PROVIDER=s3
OBJECT_STORE_BASE_URL=http://localhost:9000/edumind
EVENT_BUS_PROVIDER=redis
TASK_QUEUE_PROVIDER=redis
TASK_QUEUE_NAME=edumind:tasks
TASK_LEASE_PROVIDER=redis
TASK_LEASE_TTL_SECONDS=1800
TASK_WORKER_POLL_SECONDS=2
REDIS_URL=redis://redis:6379/0

POSTGRES_DB=edumind
POSTGRES_USER=edumind
POSTGRES_PASSWORD=edumind

S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=edumind
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=edumind
S3_SECRET_ACCESS_KEY=edumind-secret

AUTH_VALIDATION_MODE=local
IDENTITY_URL=http://identity:5101
INTERNAL_SERVICE_TOKEN=
LLM_EXECUTION_MODE=local
AI_CORE_URL=http://ai-core:5106
BILIBILI_BRIDGE_URL=http://bilibili-bridge:5001
GATEWAY_HEALTH_TIMEOUT_SECONDS=2

########################################
# LLM Core Settings
########################################
LLM_PROVIDER=gemini            # gemini | openai | claude | grok | ollama | openrouter
EMB_PROVIDER=openai             # openai | gemini | ollama | local (新增：本地模型)
LLM_TEMP=1
LLM_MAXTOK=16384

########################################
# Gemini
########################################
gemini=AI-xxxx
gemini_model=gemini-2.5-flash
gemini_embed_model=text-embedding-004

########################################
# OpenAI
########################################
OPENAI_API_KEY=sk-xxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL="https://api.openai.com/v1"
## embedding
OPENAI_EMBED_API_KEY=sk-xxxx
OPENAI_EMBED_BASE_URL="https://api.openai.com/v1"
OPENAI_EMBED_MODEL=text-embedding-3-large

########################################
# Anthropic Claude
########################################
ANTHROPIC_API_KEY=sk-ant-xxxx
CLAUDE_MODEL=claude-3-5-sonnet-latest

########################################
# DeepSeek（播客脚本深度讨论等）
########################################
DEEPSEEK_API_KEY=sk-xxxx
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 播客脚本生成使用的 LLM，默认 deepseek
PODCAST_LLM_PROVIDER=deepseek

########################################
# OpenRouter
########################################
OPENROUTER_API_KEY=sk-op-xxxx
OPENROUTER_MODEL=google/gemini-2.5-flash

########################################
# Grok (xAI)
########################################
XAI_API_KEY=sk-xai-xxxx
GROK_MODEL=grok-2-latest
GROK_BASE=https://api.x.ai/v1

########################################
# Ollama (local models)
########################################
OLLAMA_MODEL=llama4
OLLAMA_EMBED_MODEL=
OLLAMA_BASE_URL=http://localhost:11434

########################################
# Podcast / TTS
########################################
TTS_PROVIDER=edge               # edge | google | eleven
FFMPEG_PATH=ffmpeg

# Edge-tts voices
TTS_VOICE_EDGE=en-US-AvaNeural
TTS_VOICE_ALT_EDGE=en-US-AndrewNeural

# ElevenLabs
ELEVEN_API_KEY=
ELEVEN_VOICE_A=
ELEVEN_VOICE_B=

# Google TTS
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
TTS_VOICE_GOOGLE=en-US-Neural2-F
TTS_VOICE_ALT_GOOGLE=en-US-Neural2-D

########################################
# Voice Transcription
########################################
TRANSCRIPTION_PROVIDER=openai   # openai | assemblyai
# 转写建议单独配置，不要复用 DeepSeek 兼容地址
TRANSCRIPTION_OPENAI_API_KEY=sk-xxxx
TRANSCRIPTION_OPENAI_BASE_URL=https://api.openai.com/v1
TRANSCRIPTION_OPENAI_MODEL=gpt-4o-mini-transcribe
TRANSCRIPTION_LANGUAGE=
ASSEMBLYAI_API_KEY=
GOOGLE_CLOUD_PROJECT_ID=

########################################
# Teaching Video / JiMeng Video
########################################
# auto: 优先走知识点视频生成智能体（自带自然语音），未配置时回退到即梦 Visual 文生视频
JIMENG_VIDEO_PROVIDER=auto

# 推荐：知识点视频生成智能体（适合教学视频，支持 teaching_style / voice_type）
JIMENG_VIDEO_GATEWAY_BASE_URL=https://ai-gateway.vei.volces.com/v1/contents/generations/tasks
JIMENG_VIDEO_GATEWAY_API_KEY=
JIMENG_VIDEO_STUDENT_TYPE=mixed_age
JIMENG_VIDEO_TEACHING_STYLE=vivid_fun
JIMENG_VIDEO_VOICE_TYPE=zh_female_linjianvhai_moon_bigtts

# 兼容旧链路：即梦 Visual 文生视频（静音画面 + 本地配音合成）
JIMENG_ACCESS_KEY_ID=
JIMENG_SECRET_ACCESS_KEY=

# 兼容保留：如果你有方舟/其他视频推理接入点，可继续自行扩展
JIMENG_VIDEO_ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
JIMENG_VIDEO_ARK_API_KEY=
JIMENG_VIDEO_MODEL=

# 即梦 Visual 文生视频失败后，是否保留本地幻灯片兜底视频
JIMENG_VIDEO_ALLOW_FALLBACK=true

########################################
# Local Embedding (Transformers.js)
########################################
# 使用本地 all-MiniLM-L6-v2 模型进行 embedding（完全离线）
# EMB_PROVIDER=local
# LOCAL_EMBED_MODEL=Xenova/all-MiniLM-L6-v2
# LOCAL_EMBED_MODEL_PATH=./models/all-MiniLM-L6-v2  # 尽量使用当前项目内的相对路径
